@model IEnumerable<WebApplication3.Models.Student>

<h2>Students List</h2>

<a asp-action="Create" class="btn btn-primary">Add Student</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Major</th>
            <th>GPA</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Major</td>
                    <td>@item.GPA</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">
                            Delete
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-danger">
                            Details
                        </a>
                    </td>
                </tr>
        }
    </tbody>
</table>

